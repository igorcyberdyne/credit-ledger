###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
APP_TITLE="CreditBook"
APP_SHORT_TITLE=CB
APP_VERSION="1.0.0"

APP_CONTEXT_SCHEME=http
APP_CONTEXT_HOST='localhost:8080'
DEFAULT_URI="${APP_CONTEXT_SCHEME}://${APP_CONTEXT_HOST}"
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_HOST=database
DATABASE_ROOT_PASSWORD=credit_ledger
DATABASE_USER=credit_ledger
DATABASE_PASSWORD=credit_ledger
DATABASE_NAME=credit_ledger
DATABASE_PORT=3306
DATABASE_VERSION=10.9.5
DATABASE_URL="mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?serverVersion=${DATABASE_VERSION}&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
